# ── Database ──────────────────────────────────────────────
# PostgreSQL (Production/Staging):
# DATABASE_URL=postgresql+asyncpg://sigap:sigap@localhost:5432/sigap
# SQLite (Local Dev/Test) - Uncomment to use SQLite:
DATABASE_URL=sqlite+aiosqlite:///:memory:

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT & Security ────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-me-in-production
NIK_ENCRYPTION_KEY=dev-nik-encryption-key-16-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ── OPA ───────────────────────────────────────────────────
OPA_URL=http://localhost:8181
OPA_POLICY_PATH=v1/data/sigap/auth/allow

# ── Rate Limiting & Idempotency ───────────────────────────
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_WINDOW_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=86400

# ── Environment ───────────────────────────────────────────
# Options: dev, staging, prod
ENV=dev
