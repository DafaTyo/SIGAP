# SIGAP Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ──
# SQLite for dev/test, asyncpg for production
DATABASE_URL=sqlite+aiosqlite:///:memory:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/sigap

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
# REQUIRED: Generate a strong random key for production
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ── PII Encryption ──
# REQUIRED: 44-char base64 Fernet key (32 decoded bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NIK_ENCRYPTION_KEY=DFztL4aY8fIRAT8fHp24k5z1sVVg7O9pQ9eEddqu0H4=

# ── OPA (optional) ──
OPA_URL=http://opa:8181
OPA_POLICY_PATH=v1/data/sigap/auth/allow

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Idempotency ──
IDEMPOTENCY_TTL_SECONDS=86400

# ── Environment ──
# dev | staging | prod | test
ENV=dev
